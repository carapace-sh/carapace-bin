[0.000, "o", "--prepare), for example.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  10\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    The --conclude option can be specified once for all commands or multiple times, once for each com\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mmand. In the latter case, each conclude command will be run after the corresponding benchmark command\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  11\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--export-asciidoc=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mExport the timing summary statistics as an AsciiDoc table to the given FILE. Th\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116me output time unit can be changed using the --time-unit option.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  12\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--export-csv=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mExport the timing summary statistics as CSV to the given FILE. If you need the timin\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mg results for each individual run, use the JSON export format. The output time unit is always seconds\u001b[0m\u001b[m\r\n:\u001b[K"]
