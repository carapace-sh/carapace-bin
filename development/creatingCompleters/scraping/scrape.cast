[0.000, "o", "ming summary statistics as an Emacs org-mode table to the given FIL\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mE. The output time unit can be changed using the --time-unit option.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  16\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-h, --help\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mPrint help\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  17\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-i, --ignore-failure?\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mIgnore failures of the benchmarked programs. Without a value or with 'all-no\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mn-zero', all non-zero exit codes are ignored. You can also provide a comma-separated list of exit cod\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mes to ignore (e.g., --ignore-failure=1,2).\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  18\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--input=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[38;2;249;38;114m-\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.625, "o", "\r\u001b[K\u001b[38;2;131;148;150m  19\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Control where the input of the benchmark comes from.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  20\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  21\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    <WHERE> can be:\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  22\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  23\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      null:     Read from /dev/null (the default).\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  24\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  25\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      <FILE>:   Read the input from the given file.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  26\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-M, --max-runs=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mPerform at most NUM runs for each command. By default, there is no limit.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  27\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b"]
[0.000, "o", "[0m\u001b[38;2;249;38;114m-m, --min-runs=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116m'\u001b[0m\u001b[38;2;230;219;116mPerform at least NUM runs for each command (default: 10).\u001b[0m\u001b[38;2;230;219;116m'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  28\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--output=*\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[38;2;249;38;114m+\u001b[0m\u001b[m\r\n"]
[0.000, "o", "\u001b[38;2;131;148;150m  29\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Control where the output of the benchmark is redirected. Note that some programs like 'grep' dete\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mct when standard output is /dev/null and apply certain optimizations. To avoid that, consider using '\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.228, "o", "\r\u001b[K\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m--output=pipe'.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  30\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  31\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    <WHERE> can be:\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  32\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  33\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      null:     Redirect output to /dev/null (the default).\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  34\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  35\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      pipe:     Feed the output through a pipe before discarding it.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  36\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  37\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      inherit:  Don't redirect the output at all (same as '--show-output').\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  38\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  39\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      <FILE>:   Write the output to the given file.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  40\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n:\u001b[K"]
[0.545, "o", "\r\u001b[K\u001b[38;2;131;148;150m  41\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This option can be specified once for all commands or multiple times, once for each command. Note\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m: If you want to log the output of each and every iteration, you can use a shell redirection and the \u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m'$HYPERFINE_ITERATION' environment variable:\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  42\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m        hyperfine 'my-command > output-${HYPERFINE_ITERATION}.log'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  43\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  44\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-L, --parameter-list=*\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  45\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Perform benchmark runs for each value in the comma-separated list VALUES. Replaces the string '{V\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mAR}' in each command by the current parameter value.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  46\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  47\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Example:  hyperfine -L compiler gcc,clang '{compiler} -O2 main.cpp'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  48\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  49\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This performs benchmarks for 'gcc -O2 main.cpp' and 'clang -O2 main.cpp'.\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.202, "o", "\r\u001b[K\u001b[38;2;131;148;150m  50\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  51\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    The option can be specified multiple times to run benchmarks for all possible parameter combinati\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mons.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  52\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-P, --parameter-scan=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[38;2;249;38;114m-\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  53\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Perform benchmark runs for each value in the range MIN..MAX. Replaces the string '{VAR}' in each \u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mcommand by the current parameter value.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  54\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  55\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      Example:  hyperfine -P threads "]
[0.000, "o", "1 8 'make -j {threads}'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  56\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  57\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This performs benchmarks for 'make -j 1', 'make -j 2', вҖҰ, 'make -j 8'.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  58\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  59\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    To have the value increase following different patterns, use shell arithmetics.\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.215, "o", "\r\u001b[K"]
[0.001, "o", "\u001b[38;2;131;148;150m  60\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  61\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      Example: hyperfine -P size 0 3 'sleep $((2**{size}))'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  62\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  63\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This performs benchmarks with power of 2 increases: 'sleep 1', 'sleep 2', 'sleep 4', вҖҰ\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  64\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    The exact syntax may vary depending on your shell and OS.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  65\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-D, --parameter-step-size=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[38;2;249;38;114m-\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  66\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This argument requires --parameter-scan to be specified as well. Traverse the range MIN..MAX in s\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mteps of DELTA.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  67\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  68\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m      Example:  hyperfine -P delay 0.3 0.7 -D 0.2 'sleep {delay}'\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  69\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  70\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    This performs benchmarks for 'sleep 0.3', 'sleep 0.5' and 'sleep 0.7'.\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.160, "o", "\r\u001b[K\u001b[38;2;131;148;150m  71\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-p, --prepare=*\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[38;2;249;38;114m-\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  72\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Execute CMD before each timing run. This is useful for clearing disk caches, for example.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  73\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    The --prepare option can be specified once for all commands or multiple times, once for each comm\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mand. In the latter case, each preparation command will be run prior to the corresponding benchmark co\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mmmand.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  74\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--reference=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mThe reference command for the relative comparison of results. If this is unset, resul\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mts are compared with the fastest command as reference.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  75\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--reference-name=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mGive a meaningful name to the reference command.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  76\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-r, --runs=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mPerform exactly NUM runs for each command. If this option is not specified, hyperfine \u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mautomatically determines the number of runs.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  77\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-s, --setup=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mExecute CMD before each set of timing runs. This is useful for compiling your softwar\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116me with the provided parameters, or to do any other work that should happen once before a series of be\u001b[0m\u001b[m\r\n:\u001b[K"]
[0.206, "o", "\r\u001b[K"]
[0.000, "o", "\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mnchmark runs, not every time as would happen with the --prepare option.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  78\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m-S, --shell=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mSet the shell to use for executing benchmarked commands. This can be the name or the \u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mpath to the shell executable, or a full command line like \"bash --norc\". It can also be set to \"defau\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mlt\" to explicitly select the default shell on this platform. Finally, this can also be set to \"none\" \u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mto disable the shell. In this case, commands will be executed directly. They can still have arguments\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m, but more complex things like \"sleep 0.1; sleep 0.2\" are not possible without a shell.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  79\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--show-output\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mPrint the stdout and stderr of the benchmark instead of suppressing it. This will in\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mcrease the time it takes for benchmarks to run, so it should only be used for debugging purposes or w\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116mhen trying to benchmark output speed.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  80\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114m--sort=\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;249;38;114m|\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  81\u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m    Specify the sort order of the speed comparison summary and the exported tables for markup formats\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m    \u001b[0m \u001b[38;2;131;148;150mв”Ӯ\u001b[0m \u001b[38;2;230;219;116m (Markdown, AsciiDoc, org-mode):\u001b[0m\u001b[m\r\n:\u001b[K"]
