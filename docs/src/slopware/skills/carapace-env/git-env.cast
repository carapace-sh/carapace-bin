[0.133, "o", "\u001b[?25l\u001b[3A\r\r\n\r\n\u001b[19C\u001b[K\u001b[0;4mSKPASS \r\n\u001b[23C\u001b[0;me\r\n\u001b[5C\u001b[K\u001b[0;7mSKPASS\u001b[0;2;7m (is an override for the core.askpass configuration value)                                       \r\n\u001b[4C\u001b[0;m\u001b[KCONFIG_NOSYSTEM\u001b[0;2m (if set, disables the use of the system-wide configuration file)                        \r\n\u001b[4C\u001b[0;m\u001b[KDEFAULT_HASH\u001b[0;2m (sets the default hash algorithm for new repositories)                                     \r\n\u001b[4C\u001b[0;m\u001b[KDEFAULT_REF_FORMAT\u001b[0;2m (sets the default reference backend format for new repositories)                     \r\n\u001b[4C\u001b[0;m\u001b[KDIR\u001b[0;2m (is the location of the .git folder)                                                                \r\n\u001b[4C\u001b[0;m\u001b[KEXEC_PATH\u001b[0;2m (determines where Git looks for its sub-programs)                                             \r\n\u001b[4C\u001b[0;m\u001b[KEXTERNAL_DIFF\u001b[0;2m (is used as an override for the diff.external configuration value)                        \r\n\u001b[4C\u001b[0;m\u001b[KEXTERNAL_DIFF_TRUST_EXIT_CODE\u001b[0;2m (when set to true, the external diff command is expected to return exit co\r\n\u001b[4C\u001b[0;m\u001b[KGLOB_PATHSPECS\u001b[0;2m (controls the default behavior of wildcards in pathspecs)                                \r\n\u001b[4C\u001b[0;m\u001b[KINDEX_FILE\u001b[0;2m (is the path to the index file (non-bare repositories only))                                 \r\n\u001b[4C\u001b[0;m\u001b[KINDEX_VERSION\u001b[0;2m (specifies what index version is used when writing the index file out)                    \r\n\u001b[4C\u001b[0;m\u001b[KNOGLOB_PATHSPECS\u001b[0;2m (controls the default behavior of wildcards in pathspecs)                              \r\n\u001b[4C\u001b[0;m\u001b[KOBJECT_DIRECTORY\u001b[0;2m (can be used to specify the location of the directory that usually resides at ...)     \r\n\u001b[4C\u001b[0;m\u001b[KPROGRESS_DELAY\u001b[0;2m (controls how many seconds to delay before showing optional progress indicators)         \r\n\u001b[4C\u001b[0;m\u001b[KREFLOG_ACTION\u001b[0;2m (lets you specify the descriptive text written to the reflog)                             \r\n\u001b[4C\u001b[0;m\u001b[KSEQUENCE_EDITOR\u001b[0;2m (overrides the configured Git editor when editing the todo list of an interact...)      \r\n\u001b[4C\u001b[0;m\u001b[KSSH_VARIANT\u001b[0;2m (overrides Git's autodetection of the ssh variant)                                          \r\n\u001b[4C\u001b[0;m\u001b[KTRACE2\u001b[0;2m (enables more detailed trace messages from the trace2 library)                                   \r\n\u001b[4C\u001b[0;m\u001b[KTRACE2_PERF\u001b[0;2m (writes a column-based format for understanding nesting regions)                            \r\n\u001b[65C\u001b[0;m\u001b[K\u001b[0;7;35m                            \u001b[0;35mâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پ\u001b[0;m\u001b[20A\r\u001b[24C\u001b[?25h"]
