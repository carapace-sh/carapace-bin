[0.457, "o", "\u001b[?25l\u001b[2A\r\r\n\r\n\u001b[14C\u001b[K\u001b[0;4mGIT_ADVICE \r\n\u001b[0;1;37;45m COMPLETING argument \u001b[0;m \r\n\u001b[0;7mGIT_ADVICE\u001b[0;2;7m (if set to 0, disables all advice messages)                                                      \r\n\u001b[0;mGIT_ALLOW_PROTOCOL\u001b[0;2m (colon-separated list of protocols to allow)                                             \r\n\u001b[0;mGIT_ALTERNATE_OBJECT_DIRECTORIES\u001b[0;2m (is a colon-separated list which tells Git where to check for objects)     \r\n\u001b[0;mGIT_ASKPASS\u001b[0;2m (is an override for the core.askpass configuration value)                                       \r\n\u001b[0;mGIT_ATTR_SOURCE\u001b[0;2m (sets the treeish that gitattributes will be read from)                                     \r\n\u001b[0;mGIT_AUTHOR_DATE\u001b[0;2m (is the timestamp used for the 'author' field)                                              \r\n\u001b[0;mGIT_AUTHOR_EMAIL\u001b[0;2m (is the email for the 'author' field)                                                      \r\n\u001b[0;mGIT_AUTHOR_NAME\u001b[0;2m (is the human-readable name in the 'author' field)                                          \r\n\u001b[0;mGIT_CEILING_DIRECTORIES\u001b[0;2m (controls the behavior of searching for a .git directory)                           \r\n\u001b[0;mGIT_COMMITTER_DATE\u001b[0;2m (is used for the timestamp in the 'committer' field)                                     \r\n\u001b[0;mGIT_COMMITTER_EMAIL\u001b[0;2m (is the email address for the 'committer' field)                                        \r\n\u001b[0;mGIT_COMMITTER_NAME\u001b[0;2m (sets the human name for the 'committer' field)                                          \r\n\u001b[0;mGIT_COMMIT_GRAPH_PARANOIA\u001b[0;2m (enables existence check for stale commits in commit-graph at the cost of perf...)\r\n\u001b[0;mGIT_COMMON_DIR\u001b[0;2m (non-worktree files are taken from this path instead of $GIT_DIR)                            \r\n\u001b[0;mGIT_CONFIG_GLOBAL\u001b[0;2m (take the configuration from the given file instead of the global configuration)          \r\n\u001b[0;mGIT_CONFIG_NOSYSTEM\u001b[0;2m (if set, disables the use of the system-wide configuration file)                        \r\n\u001b[0;mGIT_CONFIG_SYSTEM\u001b[0;2m (take the configuration from the given file instead of the system-level config...)        \r\n\u001b[0;mGIT_DEFAULT_HASH\u001b[0;2m (sets the default hash algorithm for new repositories)                                     \r\n\u001b[0;mGIT_DEFAULT_REF_FORMAT\u001b[0;2m (sets the default reference backend format for new repositories)                     \r\n\u001b[0;7;35m                             \u001b[0;35mâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پâ”پ\u001b[0;m\u001b[20A\r\u001b[22C\u001b[?25h"]
