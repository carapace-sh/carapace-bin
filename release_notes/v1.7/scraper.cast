[0.246, "o", "# yaml-language-server: $schema=https://carapace.sh/schemas/command.json\r\nname: crush\r\ndescription: A terminal-first AI assistant for software development\r\nflags:\r\n    -C, --continue: Continue the most recent session\r\n    -h, --help: Help\r\n    -s, --session=: Continue a previous session by ID\r\n    -y, --yolo: Automatically accept all permissions (dangerous mode)\r\npersistentflags:\r\n    -D, --data-dir=: Custom crush data directory\r\n    -H, --host=: Connect to a specific crush server host (for advanced users)\r\n    -c, --cwd=: Current working directory\r\n    -d, --debug: Debug\r\ncommands:\r\n    - name: completion\r\n      description: Generate the autocompletion script for the specified shell\r\n      commands:\r\n        - name: bash\r\n          description: Generate the autocompletion script for bash\r\n          flags:\r\n            --no-descriptions: disable completion descriptions\r\n        - name: fish\r\n          description: Generate the autocompletion script for fish\r\n          flags:\r\n            --no-descriptions: disable completion descriptions\r\n        - name: powershell\r\n          description: Generate the autocompletion script for powershell\r\n          flags:\r\n            --no-descriptions: disable completion descriptions\r\n        - name: zsh\r\n          description: Generate the autocompletion script for zsh\r\n          flags:\r\n            --no-descriptions: disable completion descriptions\r\n    - name: dirs\r\n      description: Show config and data directories\r\n    - name: help [command]\r\n      description: Help about any command\r\n    - name: login [platform]\r\n      aliases:\r\n        - auth\r\n      description: Login Crush to a platform\r\n      flags:\r\n        -f, --force: Force re-authentication even if already logged in\r\n    - name: logout [platform]\r\n      aliases:\r\n        - signout\r\n      description: Logout Crush from a platform\r\n      flags:\r\n        -f, --force: Skip logout confirmation prompt\r\n    - name: logs\r\n      description: View crush logs\r\n      flags:\r\n        -f, --follow: Follow log output\r\n        -t, --tail=: 'Show only the last N lines default: 1000 for performance'\r\n    - name: man\r\n      description: Generates manpages\r\n      hidden: true\r\n    - name: models\r\n      description: List all available models from configured providers\r\n    - name: projects\r\n      description: List project directories\r\n      flags:\r\n        --json: Output as JSON\r\n    - name: run [prompt...]\r\n      aliases:\r\n        - r\r\n      description: Run a single non-interactive prompt\r\n      flags:\r\n        --small-model=: Small model to use. If not provided, uses the default small model for the provider\r\n        -C, --continue: Continue the most recent session\r\n        -m, --model=: Model to use. Accepts 'model' or 'provider/model' to disambiguate models with the same name across providers\r\n        -q, --quiet: Hide spinner\r\n        -s, --session=: Continue a previous session by ID\r\n        -v, --verbose: Show logs\r\n    - name: schema\r\n      description: Generate JSON schema for configuration\r\n      hidden: true\r\n    - name: server\r\n      description: Start the Crush server\r\n      flags:\r\n        -H, --host=: Server host (TCP or Unix socket)\r\n    - name: session\r\n      aliases:\r\n        - sessions\r\n        - s\r\n      description: Manage sessions\r\n      commands:\r\n        - name: delete <id>\r\n          aliases:\r\n            - rm\r\n          description: Delete a session\r\n          flags:\r\n            --json: output in JSON format\r\n        - name: last\r\n          description: Show most recent session\r\n          flags:\r\n            --json: output in JSON format\r\n        - name: list\r\n          aliases:\r\n            - ls\r\n          description: List all sessions\r\n          flags:\r\n            --json: output in JSON format\r\n        - name: rename <id> <title>\r\n          description: Rename a session\r\n          flags:\r\n            --json: output in JSON format\r\n        - name: show <id>\r\n          description: Show session details\r\n          flags:\r\n            --json: output in JSON format\r\n    - name: stats\r\n      description: Show usage sta"]
